{
   // autosave
   "files.autoSave": "afterDelay",
   "files.autoSaveDelay": 1000,

   // chat
   "chat.agent.enabled": false,
   "chat.commandCenter.enabled": false,
   "chat.notifyWindowOnConfirmation": "off",
   "github.copilot.enable": {
      "*": true,
      "python": false
   },
   "github.copilot.nextEditSuggestions.eagerness": "low",
   
   // c++ format
   "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 3, ContinuationIndentWidth: 6, AlignAfterOpenBracket: DontAlign, Cpp11BracedListStyle: false, ColumnLimit: 0, SpaceBeforeParens: Never, AllowShortFunctionsOnASingleLine: All, SortIncludes: false, AccessModifierOffset: -3, AllowShortEnumsOnASingleLine: true }",
   "C_Cpp.default.compilerPath": "/usr/bin/g++",
   "C_Cpp.vcFormat.indent.preserveComments": true,
   "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

   // pylance
   "python.analysis.typeCheckingMode": "standard",
   "python.analysis.typeEvaluation.strictDictionaryInference": true,
   "python.analysis.typeEvaluation.strictSetInference": true,
   "python.analysis.diagnosticSeverityOverrides": {
      "reportConstantRedefinition": "error"
   },

   // code runner
   "code-runner.runInTerminal": true,

   // debug
   "debug.onTaskErrors": "debugAnyway",

   // terminal
   "terminal.integrated.minimumContrastRatio": 1,
   "workbench.colorCustomizations": {
      "editor.foldBackground": "#3a2a1f55"
   },
   "terminal.integrated.stickyScroll.enabled": false,

   // vscode appearance
   "editor.accessibilitySupport": "on",
   "editor.cursorBlinking": "expand",
   "editor.cursorSmoothCaretAnimation": "on",
   "editor.fontLigatures": true,
   "editor.fontFamily": "'Fira Code', Consolas, monospace",
   "editor.guides.indentation": false,
   "editor.inlineSuggest.syntaxHighlightingEnabled": true,
   "editor.minimap.size": "proportional",
   "editor.minimap.renderCharacters": false,
   "editor.minimap.showSlider": "always",
   "editor.renderLineHighlight": "gutter",
   "editor.renderLineHighlightOnlyWhenFocus": true,
   "editor.selectionHighlightMultiline": true,
   "editor.tabSize": 3,
   "editor.wordWrap": "on",
   "editor.wrappingIndent": "same",
   "editor.wordBasedSuggestions": "off",
   "editor.semanticHighlighting.enabled": true,
   "editor.stickyScroll.defaultModel": "foldingProviderModel",
   "editor.suggest.insertMode": "replace",
   "[jsonc]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
   },
   "[python]": {
      "diffEditor.ignoreTrimWhitespace": false,
      "editor.defaultColorDecorators": "never",
      "gitlens.codeLens.symbolScopes": [
         "!Module"
      ],
      "editor.formatOnType": false,
      "editor.wordBasedSuggestions": "off"
   },
   "workbench.activityBar.location": "top",
   "workbench.editor.empty.hint": "hidden",
   "workbench.iconTheme": "ayu",
   "workbench.colorTheme": "Monokai Dimmed",

   // editor colors
   "editor.tokenColorCustomizations": {
      "[Dark 2026]": { // based on C++
         "textMateRules": [
            {
               "scope": "comment",
               "settings": {
                  "foreground": "#653F31",
                  "fontStyle": "italic bold"
               }
            },
            { // anything in quotes
               "scope": ["string.quoted.double", "string.quoted.single"],
               "settings": {
                  "foreground": "#95d7ca",
               },
            },
            { // operators like +, -, ==, etc
               "scope": ["keyword.operator", "punctuation.separator"],
               "settings": {
                  "foreground": "#4a8bbc",
               },
            },
            { // numeric constants
               "scope": ["constant.character", "constant.numeric"],
               "settings": {
                  "foreground": "#5bad6e",
               },
            },
            { // macros
               "scope": "entity.name.function.preprocessor",
               "settings": {
                  "foreground": "#D0C88E",
               }
            }
         ],
      },
      "[Monokai Dimmed]": { // based on Java
         "textMateRules": [
				{
					"scope": "comment",
					"settings": {
						"foreground": "#6d5767",
						"fontStyle": "italic"
					}
				},
            {
               "scope": ["string.quoted.double", "string.quoted.single"],
               "settings": {
                  "foreground": "#E07BE0",
               }
            },
            { // numeric constants
               "scope": ["constant.character", "constant.numeric"],
               "settings": {
                  "foreground": "#9FA4A9",
               },
            },
            { // build-in types
               "scope": ["storage.type", "support.type"],
               "settings": {
                  "foreground": "#F9AB55",
               }
            },
            { // all functions
               "scope": ["entity.name.function", "meta.function-call"],
               "settings": {
                  "foreground": "#6ABEA7",
               }
            },
            { // escape characters (\n \t etc.)
               "scope": "constant.character.escape",
               "settings": {
                  "foreground": "#A23E48",
                  "fontStyle": "bold"
               }
            }
         ]
      }
   },
   "editor.semanticTokenColorCustomizations": {
      "[Dark 2026]": { // based on C++
         "rules": {
            "namespace": "#ff5100",
            "property": { // class members
               "foreground": "#eaa3a3",
               "fontStyle": "italic",
            },
            "method": "#fb8c8c", // class methods
            "operator": "#477aa1", // operators like +, -, ==, etc
            "variable": { // local variables
               "foreground": "#6cbde5",
            },
         }
      },
      "[Monokai Dimmed]": { // based on Java
         "rules": {
            "namespace": {
               "foreground": "#177E89",
               "fontStyle": "italic bold"
            },
            "class": {
               "foreground": "#C8C2AE",
               "fontStyle": "italic underline"
            },
            "interface": {
               "foreground": "#C8C2AE",
               "fontStyle": "bold underline"
            },
            "property": "#FA7921", // class member variables
            "variable": "#B6DC76"  // local variables
         }
      }
   },

   // extension: background
   "background.editorBackgrounds": [
      "https://raw.githubusercontent.com/lishacodesgames/Pinterest-Board-Scraper/main/backgrounds/editor.png",
      "https://raw.githubusercontent.com/lishacodesgames/Pinterest-Board-Scraper/main/backgrounds/editor.gif"
   ],
   "background.sidebarBackgrounds": [
      "https://raw.githubusercontent.com/lishacodesgames/Pinterest-Board-Scraper/main/backgrounds/sidebar.png",
      "https://raw.githubusercontent.com/lishacodesgames/Pinterest-Board-Scraper/main/backgrounds/sidebar.gif"
   ],
   "background.panelBackgrounds": [
      "https://raw.githubusercontent.com/lishacodesgames/Pinterest-Board-Scraper/main/backgrounds/panel.png",
      "https://raw.githubusercontent.com/lishacodesgames/Pinterest-Board-Scraper/main/backgrounds/panel.gif"
   ],
   "background.useInvertedOpacity": true,
   "background.backgroundOpacity": [ 0.95, 0.93, 0.83, 0.95 ],
   "background.backgroundSize": [ "Cover", "Cover", "Cover", "Cover" ],
   "background.autoInstall": true,
   "background.backgroundChangeTime": [1800, 1200, 600, 1800], // 30 mins
   "background.backgroundAlignment": [
      "Center Center",
      "Center Center",
      "Top Left",
      "Center Center"
   ],

   // extension: Better Comments
   "better-comments.highlightPlainText": true,
   "better-comments.tags": [
      {
         //!
         "tag": "!",
         "color": "#D94359",
         "strikethrough": false,
         "underline": false,
         "backgroundColor": "transparent",
         "bold": false,
         "italic": true,
      },
      {
         //?
         "tag": "?",
         "color": "#6372CF",
         "strikethrough": false,
         "underline": false,
         "backgroundColor": "transparent",
         "bold": false,
         "italic": true,
      },
      {
         // //
         "tag": "//",
         "color": "#C586A3",
         "strikethrough": false,
         "underline": false,
         "backgroundColor": "transparent",
         "bold": false,
         "italic": true,
      },
      {
         // todo
         "tag": "todo",
         "color": "#EBD23D",
         "strikethrough": false,
         "underline": false,
         "backgroundColor": "transparent",
         "bold": false,
         "italic": true,
      },
      {
         //*
         "tag": "*",
         "color": "#98C379",
         "strikethrough": false,
         "underline": false,
         "backgroundColor": "transparent",
         "bold": false,
         "italic": true,
      },
      {
         // ~~
         "tag": "~~",
         "color": "#8A5C78",
         "strikethrough": true,
         "underline": false,
         "backgroundColor": "transparent",
         "italic": true,
      },
   ],

   // extension: colorize
   "colorize.languages": ["css", "json", "jsonc", "cpp"],
   "colorize.hide_current_line_decorations": false,

   // extension: gitlens
   "gitlens.ai.model": "vscode",
   "gitlens.ai.vscode.model": "copilot:gpt-4.1",
   "gitlens.graph.layout": "editor",
   "gitlens.views.launchpad.files.layout": "list",

   // extension: indent-rainbow
   "indentRainbow.colors": [
      "#82AAFF66",
      "#C792EA66",
      "#F78C6C61",
      "#FFCB6B61",
      "#C3E88D66",
      "#89DDFF66",
   ],
   "indentRainbow.errorColor": "#00000022",
   "indentRainbow.indicatorStyle": "light",
   "indentRainbow.lightIndicatorStyleLineWidth": 1.25,
   "indentRainbow.ignoreErrorLanguages": ["markdown"],

   // extension: prettier
   "prettier.tabWidth": 3,
   "prettier.useTabs": true,

   // extension: vim pre shortcut keys
   "vim.whichwrap": "b,w,h,l,<,>,[,]", // < > = arrow keys, [ ] = arrow keys in insert/replace mode
   "vim.handleKeys": {
      "<C-n>": false,
      "<C-k>": false,
      "<C-p>": false,
      "<C-d>": false,
      "<C-f>": false,
      ":": true,
      ";": true
   },
   "vim.normalModeKeyBindings": [
      { // fix Y to be consistent with D and C (from cursor to end of line)
         "before": ["Y"],
         "after": ["y", "$"],
      },
   ],
   "vim.normalModeKeyBindingsNonRecursive": [
      { // for convenience
         "before": ["0"],
         "after": ["^"],
      }
   ],
   "vim.insertModeKeyBindings": [
      {
         "before": ["j", "k"],
         "after": ["<Esc>"]
      },
      { // quickly move right in insert mode 
         "before": ["j", "l"],
         "after": ["<Esc>", "l", "a"]
      },
      { // quickly move left in insert mode 
         "before": ["j", "h"],
         "after": ["<Esc>", "i"]
      },
   ],
   "vim.visualModeKeyBindingsNonRecursive": [
      {
         "before": ["j", "k"],
         "after": ["<Esc>"]
      },
      { // for convenience
         "before": ["0"],
         "after": ["^"],
      }
   ],

   // extension: cmaketools
   "cmake.configureOnEdit": false,
   "cmake.configureOnOpen": false,
}
