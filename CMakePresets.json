{
   "version": 3,

   "configurePresets": [
      {
         "name": "base",
         "hidden": true,
         "generator": "Ninja",
         "binaryDir": "${sourceDir}/build/${presetName}",
         "cacheVariables": {
            "CMAKE_C_STANDARD": "99",
            "CMAKE_CXX_STANDARD": "20",
            "CMAKE_CXX_STANDARD_REQUIRED": "ON",
            "CMAKE_CXX_EXTENSIONS": "OFF",
            "OUTFILE": "${presetName}"
         }
      },

      {
         "name": "Debug",
         "inherits": "base",
         "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Debug",
            "CMAKE_CXX_FLAGS": "-D_DEBUGGING -D_LOG_INFO"
         }
      },
      {
         "name": "Symbols",
         "inherits": "base",
         "cacheVariables": {
            "CMAKE_BUILD_TYPE": "RelWithDebInfo",
            "CMAKE_CXX_FLAGS": "-D_DEBUGGING"
         }
      },
      {
         "name": "Release",
         "inherits": "base",
         "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release"
         }
      }
   ],
   "buildPresets": [
      {
         "name": "Debug",
         "configurePreset": "Debug"
      },
      {
         "name": "Symbols",
         "configurePreset": "Symbols"
      },
      {
         "name": "Release",
         "configurePreset": "Release"
      }
   ]
}
